# Maestro E2E environment variables
# Copy to .env and fill in values before running flows.
# Never commit .env to version control.

# Coach test account
COACH_EMAIL=coach@example.com
COACH_PASSWORD=TestPassword123!
COACH_DISPLAY_NAME=Test Coach

# Member test account (used in member-invite flow)
MEMBER_EMAIL=member@example.com
MEMBER_PASSWORD=TestPassword123!
MEMBER_DISPLAY_NAME=Test Member

# Invite token for member-invite flow (generate via POST /api/invites in test setup)
INVITE_TOKEN=replace-with-valid-token
